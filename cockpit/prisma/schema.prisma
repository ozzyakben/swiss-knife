generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Prompts (Phase 1 optimizer + Phase 2 library) ───────────────────────────
model Prompt {
  id        String   @id @default(cuid())
  title     String
  original  String
  optimized String?
  tags      String? // comma-separated
  favorite  Boolean  @default(false)
  source    String   @default("optimizer") // optimizer | library | import
  sourceKey String?  @unique // stable key for idempotent project-pack seeding
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([favorite])
}

// Shared engine: prompt-library variable templates (kind="prompt") AND
// brainstorming technique modes (kind="technique"). Same shape: a body with
// {{variables}} plus a JSON variable declaration.
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  kind        String   @default("prompt") // prompt | technique
  category    String? // technique sub-type, or a free group for prompts
  body        String // text with {{variable}} placeholders
  variables   String   @default("[]") // JSON string: array of VarDef
  builtin     Boolean  @default(false)
  slug        String?  @unique // stable key for idempotent seeding
  tags        String?
  favorite    Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  prompts Prompt[]
  ideas   Idea[]

  @@index([kind])
  @@index([projectId])
}

// Phase 2: email writer (compose + reply, tone, length).
model EmailDraft {
  id         String   @id @default(cuid())
  title      String?
  mode       String   @default("compose") // compose | reply
  sourceText String? // the email being replied to (reply mode)
  brief      String? // the user's intent / notes
  body       String // generated draft
  tone       String   @default("neutral") // neutral | formal | friendly | direct | warm | apologetic
  length     String   @default("medium") // short | medium | long
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// Phase 2: brainstorming output, produced by a technique Template.
model Idea {
  id            String    @id @default(cuid())
  title         String?
  topic         String
  content       String
  imagePath     String? // relative path under cockpit/uploads/ for image captures
  techniqueId   String?
  technique     Template? @relation(fields: [techniqueId], references: [id], onDelete: SetNull)
  techniqueKind String? // denormalized technique category, for legibility
  tags          String?
  favorite      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([techniqueId])
}

// Phase 3: tasks, shown as both a list and a dnd-kit Kanban board.
model Task {
  id          String    @id @default(cuid())
  title       String
  notes       String?
  status      String    @default("todo") // todo | doing | done
  priority    String    @default("medium") // low | medium | high
  module      String? // LBMH training module (e.g. Point of Sale); null for ad-hoc tasks
  dueDate     DateTime?
  order       Float     @default(0) // fractional ordering within a column
  completedAt DateTime?
  sourceKey   String?   @unique // stable key for idempotent project-pack seeding
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([projectId])
  @@index([module])
}

// Phase 4 + 7: lightweight memory facts (manual + AI-suggested), injected into
// prompts. Phase 7 ("memory loop") adds: a category, an embedding for relevance
// ranking + dedupe, decay counters, and a self-relation tracking consolidation
// lineage (a merged-away candidate points at the fact that absorbed it).
model MemoryFact {
  id         String    @id @default(cuid())
  key        String?
  value      String
  source     String    @default("manual") // manual | ai
  status     String    @default("active") // active | pending | dismissed | archived
  pinned     Boolean   @default(false)
  category   String? // glossary | preference | standard | constraint | workflow | person | project | general
  embedding  String? // JSON-encoded number[] from embeddinggemma; null until indexed
  useCount   Int       @default(0) // times injected into a tool prompt (decay signal)
  lastUsedAt DateTime? // last time this fact was injected (decay signal)
  deletedAt  DateTime? // soft-delete: non-null = in Trash (restorable); all reads filter deletedAt:null
  sourceKey  String?   @unique // stable key for idempotent project-pack seeding
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Consolidation lineage. A pending candidate that would merge into an existing
  // fact carries mergedIntoId = that fact's id (the merge is only applied on
  // human accept, so the active fact is never silently edited).
  mergedIntoId String?
  mergedInto   MemoryFact?  @relation("FactMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   MemoryFact[] @relation("FactMerge")

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([deletedAt])
}

// Phase 6: project-scoped QA pipeline (Story → Gherkin → lint → rubric).
// A QaSession is one story being worked; it holds an ordered timeline of
// QaIterations (each = a drafted .feature + its deterministic lint + its rubric
// score). Iterations come from a model follow-up ("what's missing") or a manual
// draft edit, so a session captures the refine loop, not just a single run.
model QaSession {
  id        String   @id @default(cuid())
  title     String // short label (derived from the story, user-editable)
  story     String // the original user story / requirement
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  iterations QaIteration[]

  @@index([projectId])
}

model QaIteration {
  id           String  @id @default(cuid())
  order        Int // 1-based position in the session timeline
  instruction  String? // the follow-up note that produced this iteration (null on the first)
  draftFeature String // the .feature for this iteration
  lintOk       Boolean @default(false) // deterministic lintGherkin() gate
  errors       Int     @default(0)
  warnings     Int     @default(0)
  score        Json? // rubric result { raw, verdict }; null when not (re)scored after an edit
  edited       Boolean @default(false) // true once the draft was hand-edited

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  session   QaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// Hub entity; grows across phases. Content optionally links here (onDelete: SetNull).
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  owuiUrl     String? // deep-link to this project's Open WebUI knowledge base
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prompts   Prompt[]
  templates Template[]
  emails    EmailDraft[]
  ideas     Idea[]
  tasks     Task[]
  facts     MemoryFact[]
  qaSessions QaSession[]
}

// Single-row app settings (single-user). Enforced via fixed id + upsert.
model Settings {
  id           String   @id @default("singleton")
  model        String?
  temperature  Float?
  baseUrl      String?
  theme        String?  @default("system")
  captureToken String? // shared secret for the quick-capture endpoint
  owuiApiKey   String? // Open WebUI API key for one-way prompt sync
  updatedAt    DateTime @updatedAt
}
